<Window x:Class="SmtLineAllocationUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SMT Line Allocation System"
        WindowStartupLocation="CenterScreen"
        Width="1200"
        Height="800"
        MinWidth="1000"
        MinHeight="700">
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="260" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <!-- Left navigation panel -->
    <Border Grid.Column="0"
            Background="#202733"
            Padding="20">
      <DockPanel>
        <StackPanel DockPanel.Dock="Top"
                    Margin="0,0,0,24">
          <TextBlock Text="SMT LINE MANAGER"
                     Foreground="White"
                     FontSize="18"
                     FontWeight="Bold"
                     TextWrapping="Wrap" />
          <TextBlock Text="FUNCTION MENU"
                     Foreground="#90FFFFFF"
                     Margin="0,4,0,0"
                     FontSize="12" />
        </StackPanel>

        <StackPanel DockPanel.Dock="Top"
                    VerticalAlignment="Top"
                    Margin="0,8,0,0">
          <Button x:Name="BtnSmtLineConfig"
                  Content="1. SMT Line Configuration"
                  Margin="0,0,0,8"
                  Padding="10"
                  Click="BtnSmtLineConfig_OnClick"
                  HorizontalContentAlignment="Left" />

          <Button x:Name="BtnProductCycleTime"
                  Content="2. Product Cycletime"
                  Margin="0,0,0,8"
                  Padding="10"
                  Click="BtnProductCycleTime_OnClick"
                  HorizontalContentAlignment="Left" />

          <Button x:Name="BtnProductLineAllocation"
                  Content="3. Product Line Allocation (Current)"
                  Margin="0,0,0,8"
                  Padding="10"
                  Click="BtnProductLineAllocation_OnClick"
                  HorizontalContentAlignment="Left"
                  FontSize="12" />
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- Main content area -->
    <Border Grid.Column="1"
            Background="#F4F6FA"
            Padding="20">
      <Frame x:Name="ContentFrame"
             NavigationUIVisibility="Hidden"
             Background="Transparent" />
    </Border>
  </Grid>
</Window>

