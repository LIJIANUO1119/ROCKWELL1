<Page x:Class="SmtLineAllocationUI.ProductCycleTimePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Product Cycletime">
  <Grid Background="#F4F6FA">
    <Border Background="White"
            CornerRadius="8"
            Padding="20"
            Margin="0">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0"
                    Margin="0,0,0,16">
          <TextBlock Text="Product Cycletime"
                     FontSize="20"
                     FontWeight="Bold"
                     Foreground="#333333" />
          <TextBlock Text="Query and analyze product cycle time by line."
                     Margin="0,4,0,0"
                     Foreground="#777777"
                     FontSize="12" />
        </StackPanel>

        <Grid Grid.Row="1">
          <StackPanel Margin="0">
            <TextBlock Text="Actions"
                       FontWeight="SemiBold"
                       Margin="0,0,0,8" />

            <Button x:Name="BtnQueryAllCycleTime"
                    Content="Query product cycletime"
                    Height="36"
                    Margin="0,0,0,8"
                    Click="BtnQueryAllCycleTime_OnClick" />

            <Button x:Name="BtnShowNotMeetingTarget"
                    Content="Report: not meeting target"
                    Height="36"
                    Margin="0,0,0,8"
                    Click="BtnShowNotMeetingTarget_OnClick" />

            <Button x:Name="BtnShowExceedTarget"
                    Content="Report: exceed target"
                    Height="36"
                    Margin="0,0,0,8"
                    Click="BtnShowExceedTarget_OnClick" />

            <Button x:Name="BtnExportAllProductCycletime"
                    Content="Export: all product cycletime"
                    Height="36"
                    Margin="0,0,0,8"
                    Click="BtnExportAllProductCycletime_OnClick" />

            <Button x:Name="BtnViewUploadedData"
                    Content="View uploaded data"
                    Height="36"
                    Margin="0,0,0,14"
                    Click="BtnViewUploadedData_OnClick" />

            <TextBlock Text="Data upload"
                       FontWeight="SemiBold"
                       Margin="0,0,0,8" />

            <Button x:Name="BtnUploadBuildToModule"
                    Content="Upload build-to-module"
                    Height="36"
                    Margin="0,0,0,4"
                    Click="BtnUploadBuildToModule_OnClick" />
            <TextBlock Foreground="#777777"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Margin="0,0,0,8">
              <Run Text="Saved columns (CSV headers): " />
              <Run FontWeight="SemiBold"
                   Text="Build #" />
              <Run Text=", " />
              <Run FontWeight="SemiBold"
                   Text="Build Key" />
              <Run Text=", " />
              <Run FontWeight="SemiBold"
                   Text="Module #" />
              <Run Text=", " />
              <Run FontWeight="SemiBold"
                   Text="PCB" />
              <Run Text=". Skips empty PCB and non-numeric Build Key; per Build # keeps the row with the largest Build Key. Existing Build # values in the database are kept; only new Build # rows from the file are added." />
            </TextBlock>

            <Button x:Name="BtnUploadMachineCycletime"
                    Content="Upload machine cycletime"
                    Height="36"
                    Margin="0,0,0,4"
                    Click="BtnUploadMachineCycletime_OnClick" />
            <TextBlock Foreground="#777777"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Margin="0,0,0,8">
              <Run Text="Saved columns (CSV headers): " />
              <Run FontWeight="SemiBold" Text="LINE" />
              <Run Text=", " />
              <Run FontWeight="SemiBold" Text="ASSEMBLYNO" />
              <Run Text=", " />
              <Run FontWeight="SemiBold" Text="Side" />
              <Run Text=", " />
              <Run FontWeight="SemiBold" Text="MACHINENAME" />
              <Run Text=", " />
              <Run FontWeight="SemiBold" Text="MACHINE_MIN_CYCLETIME" />
              <Run Text=", " />
              <Run FontWeight="SemiBold" Text="MACHINE_MEDIUM_CYCLETIME" />
              <Run Text=", " />
              <Run FontWeight="SemiBold" Text="ADM_CURRENT_CYCLETIME" />
              <Run Text=". Skips rows where BOARDSPROCESSED is non-numeric or &lt; 10. Within each file, duplicate (LINE, ASSEMBLYNO, Side, MACHINENAME) keeps only the row with the latest PANELENDTIME. New rows are appended; existing database rows are kept." />
            </TextBlock>
          </StackPanel>
        </Grid>
      </Grid>
    </Border>
  </Grid>
</Page>

