<Page x:Class="SmtLineAllocationUI.SmtLineConfigurationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="SMT Line Configuration"
      Loaded="Page_Loaded">
  <Grid Background="#F4F6FA"
        Margin="0">
    <Border Background="White"
            CornerRadius="8"
            Padding="20"
            Margin="0">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"
                    Margin="0,0,0,16">
          <TextBlock Text="SMT Line Configuration"
                     FontSize="20"
                     FontWeight="Bold"
                     Foreground="#333333" />
          <TextBlock Text="Configure SMT lines, machines, software and nozzle setup."
                     Margin="0,4,0,0"
                     Foreground="#777777"
                     FontSize="12" />
        </StackPanel>

        <Grid Grid.Row="1">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <!-- Main actions -->
          <StackPanel Grid.Column="0"
                      Margin="0,0,24,0">
            <TextBlock Text="Line &amp; Machine Overview"
                       FontWeight="SemiBold"
                       Margin="0,0,0,8" />

            <Button x:Name="BtnViewLines"
                    Content="View line configuration"
                    Height="36"
                    Margin="0,0,0,8"
                    FontSize="12"
                    Click="BtnViewLines_OnClick" />

            <Button x:Name="BtnViewMachines"
                    Content="View machine nozzle configuration"
                    Height="36"
                    Margin="0,0,0,8"
                    FontSize="12"
                    Click="BtnViewMachines_OnClick" />

            <Button x:Name="BtnDataActions"
                    Content="Data actions"
                    Height="36"
                    Margin="0,0,0,8"
                    FontSize="12"
                    Click="BtnDataActions_OnClick" />

            <TextBlock Text="Use View line / View machine to open full-screen tables."
                       Foreground="#777777"
                       FontSize="12"
                       TextWrapping="Wrap"
                       Margin="0,4,0,0" />
          </StackPanel>

          <!-- Constraints setup -->
          <ScrollViewer Grid.Column="1"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled"
                        Padding="0,0,4,0">
            <StackPanel>
              <TextBlock Text="Assign line constraints"
                         FontWeight="SemiBold"
                         Margin="0,0,0,8" />

              <Button x:Name="BtnManageConstraintOptions"
                      Content="Manage constraint options…"
                      Height="34"
                      Margin="0,0,0,14"
                      Click="BtnManageConstraintOptions_OnClick" />

              <TextBlock Text="Line"
                         Foreground="#555555"
                         Margin="0,0,0,4" />
              <ComboBox x:Name="CmbConstraintLine"
                        Height="32"
                        Margin="0,0,0,8"
                        SelectionChanged="CmbConstraintLine_OnSelectionChanged" />

              <StackPanel x:Name="PnlLineConstraintChecks"
                          Margin="0,0,0,10" />

              <TextBlock Text="Remark"
                         Foreground="#555555"
                         Margin="0,0,0,4" />
              <TextBox x:Name="TxtConstraintRemark"
                       Height="72"
                       TextWrapping="Wrap"
                       AcceptsReturn="True"
                       VerticalScrollBarVisibility="Auto"
                       Margin="0,0,0,10" />

              <Button x:Name="BtnSaveConstraints"
                      Content="Save constraints"
                      Height="36"
                      Margin="0,0,0,12"
                      Click="BtnSaveConstraints_OnClick" />

              <Button x:Name="BtnViewAllConstraints"
                      Content="View all constraints"
                      Height="36"
                      Margin="0,0,0,0"
                      Click="BtnViewAllConstraints_OnClick" />
            </StackPanel>
          </ScrollViewer>
        </Grid>
      </Grid>
    </Border>
  </Grid>
</Page>

