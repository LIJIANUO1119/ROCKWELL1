<Window x:Class="SmtLineAllocationUI.ConstraintOptionsManageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manage constraint options"
        Width="720"
        Height="480"
        MinWidth="560"
        MinHeight="360"
        WindowStartupLocation="CenterOwner"
        Background="#F4F6FA">
  <Border Background="White"
          CornerRadius="8"
          Padding="16"
          Margin="12">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <StackPanel Grid.Row="0"
                  Margin="0,0,0,12">
        <TextBlock Text="Constraint options"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Foreground="#333333" />
        <TextBlock Text="Add, edit, or delete boolean options for each line (values are mirrored to machines on that line when you save)."
                   Margin="0,6,0,0"
                   Foreground="#666666"
                   FontSize="12"
                   TextWrapping="Wrap" />
      </StackPanel>

      <DataGrid x:Name="GridOptions"
                Grid.Row="1"
                AutoGenerateColumns="False"
                CanUserAddRows="False"
                CanUserDeleteRows="False"
                IsReadOnly="True"
                SelectionMode="Single"
                HeadersVisibility="Column"
                GridLinesVisibility="Horizontal"
                BorderBrush="#DDDDDD"
                AlternatingRowBackground="#FAFAFA">
        <DataGrid.Columns>
          <DataGridTextColumn Header="Display name"
                              Binding="{Binding DisplayName}"
                              Width="*" />
          <DataGridTextColumn Header="Sort"
                              Binding="{Binding SortOrder}"
                              Width="56" />
          <DataGridCheckBoxColumn Header="Active"
                                  Binding="{Binding IsActive}"
                                  Width="64" />
        </DataGrid.Columns>
      </DataGrid>

      <StackPanel Grid.Row="2"
                  Orientation="Horizontal"
                  HorizontalAlignment="Right"
                  Margin="0,14,0,0">
        <Button x:Name="BtnAdd"
                Content="Add"
                Width="88"
                Height="32"
                Margin="0,0,8,0"
                Click="BtnAdd_OnClick" />
        <Button x:Name="BtnEdit"
                Content="Edit"
                Width="88"
                Height="32"
                Margin="0,0,8,0"
                Click="BtnEdit_OnClick" />
        <Button x:Name="BtnDelete"
                Content="Delete"
                Width="88"
                Height="32"
                Margin="0,0,16,0"
                Click="BtnDelete_OnClick" />
        <Button x:Name="BtnClose"
                Content="Close"
                Width="88"
                Height="32"
                IsDefault="True"
                Click="BtnClose_OnClick" />
      </StackPanel>
    </Grid>
  </Border>
</Window>
