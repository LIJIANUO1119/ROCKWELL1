<Page x:Class="SmtLineAllocationUI.FamilyGroupingQueryResultsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Family groupings query results">
  <Grid Background="#F4F6FA"
        Margin="0">
    <Border Background="White"
            CornerRadius="8"
            Padding="20"
            Margin="0">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Margin="0,0,0,16">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <Button x:Name="BtnBack"
                  Grid.Column="0"
                  Content="Back"
                  Width="110"
                  Height="36"
                  HorizontalAlignment="Left"
                  Click="BtnBack_OnClick" />

          <StackPanel Grid.Column="1"
                      VerticalAlignment="Center">
            <TextBlock x:Name="TxtTitle"
                       Text="Family groupings query"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="#333333"
                       HorizontalAlignment="Center"
                       TextAlignment="Center" />
            <TextBlock x:Name="TxtSubtitle"
                       Text=""
                       Margin="0,6,0,0"
                       Foreground="#777777"
                       FontSize="12"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Grid>

        <DataGrid x:Name="GridData"
                  Grid.Row="1"
                  AutoGenerateColumns="True"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  EnableRowVirtualization="True"
                  SelectionMode="Single"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  ScrollViewer.CanContentScroll="True" />
      </Grid>
    </Border>
  </Grid>
</Page>
